        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 화면에서 지정한 프록시 서버를 통해 AI API에 연결합니다. API 키는 앱에 포함되어 있지 않습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se conecta a la API de IA a través del servidor proxy configurado en Ajustes. Sin claves API en la app."
